  "business_model_taxonomy": {
    "open_core": "Open source base + proprietary features/hosting",
    "platform_play": "Open source to build ecosystem, monetize adjacent layer",
    "strategic_oss": "Open source to commoditize competitor's advantage",
    "nonprofit_saas": "Non-profit entity offering hosted version",
    "pure_community": "No company, maintained by volunteers/consortium",
    "public_domain": "Explicitly no copyright restrictions",
