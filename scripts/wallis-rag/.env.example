# Wallis RAG pipeline — environment variables
# Copy this file to .env and fill in real values. Do NOT commit .env.

# OpenAI API (for embeddings)
OPENAI_API_KEY=sk-...

# Cloudflare R2 (S3-compatible)
# Account ID confirmed via Cloudflare MCP: 186ee77dc3cb07be2e88eb78137860c7
R2_ACCOUNT_ID=186ee77dc3cb07be2e88eb78137860c7

# R2 API token credentials — generate at:
# Cloudflare dashboard → R2 → Manage API tokens → Create API token
# Use "Object Read & Write" for the wallis-corpus bucket only.
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...

# Bucket — confirmed to exist via Cloudflare MCP
R2_BUCKET_NAME=wallis-corpus

# Optional: paths (sensible defaults; override only if running from elsewhere)
# WALLIS_CORPUS_DIR=../../transcripts/wallis-corpus/blog
# WALLIS_MANIFEST_PATH=../../transcripts/wallis-corpus/_metadata/manifest.json
